# Zoning Compliance Checker Environment Configuration

# Application Settings
SECRET_KEY=zoning-compliance-production-key-change-in-production
FLASK_ENV=development
PORT=5000

# Enterprise API Configuration
ENTERPRISE_API_KEY=your-enterprise-api-key-here

# External Services
OPENWEATHER_API_KEY=your-openweather-api-key-here

# Database Configuration (Optional - defaults to SQLite)
DATABASE_URL=sqlite:///zoning_compliance.db
REDIS_URL=redis://localhost:6379

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Security Settings
CORS_ORIGINS=*
RATE_LIMIT=100/hour

# Performance Settings
CACHE_TTL=3600
MAX_WORKERS=4
